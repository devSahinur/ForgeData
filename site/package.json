{
  "name": "forgedata-site",
  "private": true,
  "version": "0.0.0",
  "description": "Landing page + documentation site for ForgeData, built with plain HTML and Tailwind CSS.",
  "scripts": {
    "build": "tailwindcss -i ./src/input.css -o ./dist/output.css --minify",
    "dev": "tailwindcss -i ./src/input.css -o ./dist/output.css --watch",
    "serve": "npx --yes serve ."
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "tailwindcss": "^3.4.13"
  }
}
